{
  "name": "uxml-uss-language-tools",
  "displayName": "UXML & USS Language Tools",
  "description": "Language support for Unity UI Toolkit files: syntax highlighting, snippets, IntelliSense, hover docs, diagnostics and quick fixes for .uxml and .uss files.",
  "version": "1.0.1",
  "publisher": "helizac",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/helizac/uxml-uss-language-tools.git"
  },
  "bugs": {
    "url": "https://github.com/helizac/uxml-uss-language-tools/issues"
  },
  "homepage": "https://github.com/helizac/uxml-uss-language-tools#readme",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "unity",
    "uxml",
    "uss",
    "ui toolkit",
    "ui builder"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:uxml",
    "onLanguage:uss"
  ],
  "contributes": {
    "languages": [
      {
        "id": "uxml",
        "aliases": [
          "Unity UXML",
          "uxml"
        ],
        "extensions": [
          ".uxml"
        ],
        "configuration": "./language-configuration-uxml.json"
      },
      {
        "id": "uss",
        "aliases": [
          "Unity USS",
          "uss"
        ],
        "extensions": [
          ".uss"
        ],
        "configuration": "./language-configuration-uss.json"
      }
    ],
    "grammars": [
      {
        "language": "uxml",
        "scopeName": "text.xml.uxml",
        "path": "./syntaxes/uxml.tmLanguage.json"
      },
      {
        "language": "uss",
        "scopeName": "source.uss",
        "path": "./syntaxes/uss.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "uxml",
        "path": "./snippets/uxml.json"
      },
      {
        "language": "uss",
        "path": "./snippets/uss.json"
      }
    ],
    "configurationDefaults": {
      "[uxml]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.wordWrap": "off"
      },
      "[uss]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "npx --yes @vscode/vsce package",
    "publish:vsce": "npx --yes @vscode/vsce publish",
    "publish:ovsx": "npx --yes ovsx publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.x",
    "@types/vscode": "^1.75.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  }
}
