{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["<", ">"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "<!--", "close": "-->", "notIn": ["comment", "string"] },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "'", "close": "'" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["<", ">"],
    ["'", "'"],
    ["\"", "\""],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "onEnterRules": [
    {
      "beforeText": "<(?!\\?|(?:area|base|br|col|frame|hr|html|img|input|link|meta|param)\\b|[^>]*/>)([_:\\w][_:\\w-.\\d]*)([^/>]*(?!/)>)[^<]*$",
      "afterText": "^</([_:\\w][_:\\w-.\\d]*)\\s*>",
      "action": { "indent": "indentOutdent" }
    },
    {
      "beforeText": "<(?!\\?|(?:area|base|br|col|frame|hr|html|img|input|link|meta|param)\\b|[^>]*/>)([_:\\w][_:\\w-.\\d]*)([^/>]*(?!/)>)[^<]*$",
      "action": { "indent": "indent" }
    }
  ]
}
